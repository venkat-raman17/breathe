  "translations": [
    { "key": "tradition.yogic.name", "locale": "en", "value": "Yogic" },
    { "key": "tradition.yogic.name", "locale": "hi", "value": "योगिक" },
    { "key": "tradition.yogic.name", "locale": "ta", "value": "யோகா மரபு" },

    { "key": "tradition.yogic.cosmology", "locale": "en", "value": "Prāṇa is the vital life-force of which breath is the grossest expression; prāṇāyāma works with it through channels (nāḍīs) and centers (chakras)." },
    { "key": "tradition.yogic.cosmology", "locale": "hi", "value": "प्राण वह जीवनी-शक्ति है जिसकी श्वास स्थूलतम अभिव्यक्ति है; प्राणायाम इसे नाड़ियों और चक्रों के माध्यम से साधता है।" },
    { "key": "tradition.yogic.cosmology", "locale": "ta", "value": "பிராணன் என்பது உயிராற்றல்; மூச்சு அதன் மிகப் பருண்மையான வெளிப்பாடு. பிராணாயாமம் இதை நாடிகள் மற்றும் சக்கரங்கள் வழியாக செயல்படுத்துகிறது." },

    { "key": "tradition.yogic.lineage", "locale": "en", "value": "Codified from the Upanishads and Patañjali through the medieval Haṭha-yoga corpus (Haṭha Yoga Pradīpikā, Gheraṇḍa Saṁhitā)." },
    { "key": "tradition.yogic.lineage", "locale": "hi", "value": "उपनिषदों और पतंजलि से लेकर मध्यकालीन हठयोग ग्रंथों (हठयोग प्रदीपिका, घेरण्ड संहिता) तक संहिताबद्ध।" },
    { "key": "tradition.yogic.lineage", "locale": "ta", "value": "உபநிடதங்கள் மற்றும் பதஞ்சலி முதல் இடைக்கால ஹட யோக நூல்கள் (ஹட யோக பிரதீபிகை, கேரண்ட சம்ஹிதை) வரை தொகுக்கப்பட்டது." },

    { "key": "tradition.yogic.beliefLabel", "locale": "en", "value": "Prāṇa and the chakras are a contemplative, belief-based model of felt experience — not a measured anatomical or medical structure." },
    { "key": "tradition.yogic.beliefLabel", "locale": "hi", "value": "प्राण और चक्र अनुभूति का एक चिंतनशील, विश्वास-आधारित प्रतिमान हैं — कोई मापित शारीरिक या चिकित्सकीय संरचना नहीं।" },
    { "key": "tradition.yogic.beliefLabel", "locale": "ta", "value": "பிராணனும் சக்கரங்களும் உணர்வின் ஒரு தியான, நம்பிக்கை அடிப்படையிலான மாதிரி — அளவிடப்பட்ட உடற்கூறு அல்லது மருத்துவ அமைப்பு அல்ல." },

    { "key": "center.muladhara.name", "locale": "en", "value": "Mūlādhāra (Root)" },
    { "key": "center.muladhara.name", "locale": "hi", "value": "मूलाधार" },
    { "key": "center.muladhara.name", "locale": "ta", "value": "மூலாதாரம்" },
    { "key": "center.muladhara.note", "locale": "en", "value": "Classically deep red with a yellow earth-square (pṛthvī)." },
    { "key": "center.muladhara.note", "locale": "hi", "value": "शास्त्रीय रूप से गहरा लाल, साथ में पीला पृथ्वी-चतुर्भुज।" },
    { "key": "center.muladhara.note", "locale": "ta", "value": "பாரம்பரியமாக கடும் சிவப்பு, மண்ணைக் குறிக்கும் மஞ்சள் சதுரத்துடன்." },

    { "key": "center.svadhisthana.name", "locale": "en", "value": "Svādhiṣṭhāna (Sacral)" },
    { "key": "center.svadhisthana.name", "locale": "hi", "value": "स्वाधिष्ठान" },
    { "key": "center.svadhisthana.name", "locale": "ta", "value": "சுவாதிஷ்டானம்" },
    { "key": "center.svadhisthana.note", "locale": "en", "value": "Vermilion petals with a white water-crescent (candra)." },
    { "key": "center.svadhisthana.note", "locale": "hi", "value": "श्वेत जल-अर्धचंद्र के साथ सिंदूरी पंखुड़ियाँ।" },
    { "key": "center.svadhisthana.note", "locale": "ta", "value": "வெண் நிலா-பிறையுடன் சிந்தூர இதழ்கள்." },

    { "key": "center.manipura.name", "locale": "en", "value": "Maṇipūra (Navel)" },
    { "key": "center.manipura.name", "locale": "hi", "value": "मणिपूर" },
    { "key": "center.manipura.name", "locale": "ta", "value": "மணிபூரகம்" },
    { "key": "center.manipura.note", "locale": "en", "value": "Classically a red fire-triangle — not the modern yellow." },
    { "key": "center.manipura.note", "locale": "hi", "value": "शास्त्रीय रूप से लाल अग्नि-त्रिकोण — आधुनिक पीला नहीं।" },
    { "key": "center.manipura.note", "locale": "ta", "value": "பாரம்பரியமாக சிவப்பு அக்னி-முக்கோணம் — நவீன மஞ்சள் அல்ல." },

    { "key": "center.anahata.name", "locale": "en", "value": "Anāhata (Heart)" },
    { "key": "center.anahata.name", "locale": "hi", "value": "अनाहत" },
    { "key": "center.anahata.name", "locale": "ta", "value": "அநாகதம்" },
    { "key": "center.anahata.note", "locale": "en", "value": "Smoke-grey petals with a hexagram; modern systems use green." },
    { "key": "center.anahata.note", "locale": "hi", "value": "षट्कोण के साथ धूम्र-धूसर पंखुड़ियाँ; आधुनिक प्रणाली में हरा।" },
    { "key": "center.anahata.note", "locale": "ta", "value": "அறுகோணத்துடன் புகை-சாம்பல் இதழ்கள்; நவீன முறையில் பச்சை." },

    { "key": "center.vishuddha.name", "locale": "en", "value": "Viśuddha (Throat)" },
    { "key": "center.vishuddha.name", "locale": "hi", "value": "विशुद्ध" },
    { "key": "center.vishuddha.name", "locale": "ta", "value": "விசுத்தி" },
    { "key": "center.vishuddha.note", "locale": "en", "value": "Smoky-purple petals with a white moon-disc — classically not blue." },
    { "key": "center.vishuddha.note", "locale": "hi", "value": "श्वेत चंद्र-बिंब के साथ धूम्र-बैंगनी पंखुड़ियाँ — शास्त्रीय रूप से नीला नहीं।" },
    { "key": "center.vishuddha.note", "locale": "ta", "value": "வெண் நிலா-வட்டத்துடன் புகை-ஊதா இதழ்கள் — பாரம்பரியமாக நீலம் அல்ல." },

    { "key": "center.ajna.name", "locale": "en", "value": "Ājñā (Brow)" },
    { "key": "center.ajna.name", "locale": "hi", "value": "आज्ञा" },
    { "key": "center.ajna.name", "locale": "ta", "value": "ஆக்ஞா" },
    { "key": "center.ajna.note", "locale": "en", "value": "Two white petals with OM; modern systems use indigo." },
    { "key": "center.ajna.note", "locale": "hi", "value": "ॐ के साथ दो श्वेत पंखुड़ियाँ; आधुनिक प्रणाली में नील।" },
    { "key": "center.ajna.note", "locale": "ta", "value": "ௐ உடன் இரு வெண் இதழ்கள்; நவீன முறையில் இண்டிகோ." },

    { "key": "center.sahasrara.name", "locale": "en", "value": "Sahasrāra (Crown)" },
    { "key": "center.sahasrara.name", "locale": "hi", "value": "सहस्रार" },
    { "key": "center.sahasrara.name", "locale": "ta", "value": "சகஸ்ராரம்" },
    { "key": "center.sahasrara.note", "locale": "en", "value": "A thousand-petalled lotus, luminous white." },
    { "key": "center.sahasrara.note", "locale": "hi", "value": "सहस्र-दल कमल, दीप्त श्वेत।" },
    { "key": "center.sahasrara.note", "locale": "ta", "value": "ஆயிரம் இதழ் தாமரை, ஒளிரும் வெண்மை." },

