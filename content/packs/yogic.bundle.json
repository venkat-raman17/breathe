    { "key": "channel.sushumna.polarity", "locale": "hi", "value": "केंद्रीय · अग्नि / अक्ष" },
    { "key": "channel.sushumna.polarity", "locale": "ta", "value": "மைய · அக்னி / அச்சு" },
    { "key": "channel.ida.name", "locale": "en", "value": "Iḍā" },
    { "key": "channel.ida.name", "locale": "hi", "value": "इडा" },
    { "key": "channel.ida.name", "locale": "ta", "value": "இடா" },
    { "key": "channel.ida.polarity", "locale": "en", "value": "left · lunar / cooling" },
    { "key": "channel.ida.polarity", "locale": "hi", "value": "वाम · चंद्र / शीतल" },
    { "key": "channel.ida.polarity", "locale": "ta", "value": "இடது · சந்திர / குளிர்" },
    { "key": "channel.pingala.name", "locale": "en", "value": "Piṅgalā" },
    { "key": "channel.pingala.name", "locale": "hi", "value": "पिंगला" },
    { "key": "channel.pingala.name", "locale": "ta", "value": "பிங்களா" },
    { "key": "channel.pingala.polarity", "locale": "en", "value": "right · solar / heating" },
    { "key": "channel.pingala.polarity", "locale": "hi", "value": "दक्षिण · सूर्य / उष्ण" },
    { "key": "channel.pingala.polarity", "locale": "ta", "value": "வலது · சூரிய / வெப்பம்" },

    { "key": "tech.nadi_shodhana.name", "locale": "en", "value": "Nāḍī Śodhana" },
    { "key": "tech.nadi_shodhana.name", "locale": "hi", "value": "नाड़ी शोधन" },
    { "key": "tech.nadi_shodhana.name", "locale": "ta", "value": "நாடி சுத்தி" },
    { "key": "tech.nadi_shodhana.summary", "locale": "en", "value": "Alternate-nostril breathing to balance the iḍā and piṅgalā channels and settle the mind." },
    { "key": "tech.nadi_shodhana.summary", "locale": "hi", "value": "इडा और पिंगला नाड़ियों को संतुलित करने और मन को शांत करने हेतु अनुलोम-विलोम श्वास।" },
    { "key": "tech.nadi_shodhana.summary", "locale": "ta", "value": "இடா மற்றும் பிங்களா நாடிகளை சமன் செய்து மனதை அமைதிப்படுத்தும் மாற்று-நாசி மூச்சு." },
    { "key": "tech.nadi_shodhana.felt", "locale": "en", "value": "Even, quiet, balanced — both nostrils flowing." },
    { "key": "tech.nadi_shodhana.felt", "locale": "hi", "value": "सम, शांत, संतुलित — दोनों नथुनों से प्रवाह।" },
    { "key": "tech.nadi_shodhana.felt", "locale": "ta", "value": "சீரான, அமைதியான, சமநிலை — இரு நாசிகளிலும் ஓட்டம்." },
    { "key": "tech.nadi_shodhana.safety", "locale": "en", "value": "Keep it comfortable; build retention slowly. Ease off with respiratory or cardiovascular conditions." },
    { "key": "tech.nadi_shodhana.safety", "locale": "hi", "value": "इसे सहज रखें; कुम्भक धीरे-धीरे बढ़ाएँ। श्वसन या हृदय संबंधी स्थिति में सावधानी।" },
    { "key": "tech.nadi_shodhana.safety", "locale": "ta", "value": "வசதியாக வைத்திருங்கள்; நிறுத்தத்தை மெதுவாக அதிகரிக்கவும். சுவாச அல்லது இதய நிலைகளில் கவனம்." },

    { "key": "tech.ujjayi.name", "locale": "en", "value": "Ujjāyī" },
    { "key": "tech.ujjayi.name", "locale": "hi", "value": "उज्जायी" },
    { "key": "tech.ujjayi.name", "locale": "ta", "value": "உஜ்ஜாயி" },
    { "key": "tech.ujjayi.summary", "locale": "en", "value": "‘Victorious breath’ — a soft ocean-like sound from a gently narrowed throat." },
    { "key": "tech.ujjayi.summary", "locale": "hi", "value": "‘विजयी श्वास’ — हल्के संकुचित कंठ से समुद्र-सी कोमल ध्वनि।" },
    { "key": "tech.ujjayi.summary", "locale": "ta", "value": "‘வெற்றி மூச்சு’ — மெதுவாக சுருங்கிய தொண்டையிலிருந்து கடல் போன்ற மென் ஒலி." },
    { "key": "tech.ujjayi.felt", "locale": "en", "value": "Audible, oceanic, soothing at the back of the throat." },
    { "key": "tech.ujjayi.felt", "locale": "hi", "value": "श्रव्य, समुद्र-सी, कंठ के पिछले भाग में सुखद।" },
    { "key": "tech.ujjayi.felt", "locale": "ta", "value": "கேட்கும், கடல்போன்ற, தொண்டையின் பின்புறம் இதமான." },

    { "key": "tech.bhramari.name", "locale": "en", "value": "Bhrāmarī" },
    { "key": "tech.bhramari.name", "locale": "hi", "value": "भ्रामरी" },
    { "key": "tech.bhramari.name", "locale": "ta", "value": "ப்ராமரி" },
    { "key": "tech.bhramari.summary", "locale": "en", "value": "‘Humming-bee breath’ — a long, gentle hum on the exhale to soothe the nerves." },
    { "key": "tech.bhramari.summary", "locale": "hi", "value": "‘भ्रामरी’ — नसों को शांत करने हेतु श्वास छोड़ते समय लंबी कोमल गुंजन।" },
    { "key": "tech.bhramari.summary", "locale": "ta", "value": "‘வண்டு மூச்சு’ — நரம்புகளை அமைதிப்படுத்த மூச்சை வெளியிடும்போது நீண்ட மென் ரீங்காரம்." },
    { "key": "tech.bhramari.felt", "locale": "en", "value": "Vibration in the skull, sinuses, and brow; deeply quieting." },
    { "key": "tech.bhramari.felt", "locale": "hi", "value": "खोपड़ी, साइनस और भृकुटि में कंपन; गहन शांति।" },
    { "key": "tech.bhramari.felt", "locale": "ta", "value": "மண்டை, சைனஸ், புருவம் ஆகியவற்றில் அதிர்வு; ஆழ்ந்த அமைதி." },

    { "key": "tech.bhastrika.name", "locale": "en", "value": "Bhastrikā" },
    { "key": "tech.bhastrika.name", "locale": "hi", "value": "भस्त्रिका" },
    { "key": "tech.bhastrika.name", "locale": "ta", "value": "பஸ்த்ரிகா" },
    { "key": "tech.bhastrika.summary", "locale": "en", "value": "‘Bellows breath’ — rapid, forceful breathing for heat and vitality. Advanced." },
    { "key": "tech.bhastrika.summary", "locale": "hi", "value": "‘धौंकनी श्वास’ — ऊष्मा और ओज हेतु तीव्र, सशक्त श्वास। उन्नत।" },
    { "key": "tech.bhastrika.summary", "locale": "ta", "value": "‘துருத்தி மூச்சு’ — வெப்பம் மற்றும் சக்திக்கான வேகமான, வலிமையான மூச்சு. மேம்பட்டது." },
    { "key": "tech.bhastrika.felt", "locale": "en", "value": "Strong warmth, energization, vigorous pumping; possible light-headedness." },
    { "key": "tech.bhastrika.felt", "locale": "hi", "value": "तीव्र ऊष्मा, स्फूर्ति, सशक्त पम्पिंग; हल्का चक्कर संभव।" },
    { "key": "tech.bhastrika.felt", "locale": "ta", "value": "வலுவான வெப்பம், சுறுசுறுப்பு, வீரியமான இயக்கம்; லேசான மயக்கம் சாத்தியம்." },
    { "key": "tech.bhastrika.safety", "locale": "en", "value": "Not in pregnancy, hypertension, heart disease, hernia, epilepsy, or glaucoma. Stop if dizzy. Never near water." },
    { "key": "tech.bhastrika.safety", "locale": "hi", "value": "गर्भावस्था, उच्च रक्तचाप, हृदय रोग, हर्निया, मिर्गी या ग्लूकोमा में नहीं। चक्कर आने पर रोकें। पानी के पास कभी नहीं।" },
    { "key": "tech.bhastrika.safety", "locale": "ta", "value": "கர்ப்பம், உயர் ரத்த அழுத்தம், இதய நோய், குடலிறக்கம், வலிப்பு அல்லது கிளௌகோமாவில் வேண்டாம். மயக்கம் வந்தால் நிறுத்தவும். தண்ணீர் அருகில் ஒருபோதும் வேண்டாம்." },

    { "key": "script.prana_rise.summary", "locale": "en", "value": "Prāṇa is drawn up the central channel (suṣumnā) toward the crown." },
    { "key": "script.prana_rise.summary", "locale": "hi", "value": "प्राण को केंद्रीय नाड़ी (सुषुम्ना) से ऊपर सहस्रार की ओर ले जाया जाता है।" },
    { "key": "script.prana_rise.summary", "locale": "ta", "value": "பிராணன் மைய நாடி (சுழுமுனை) வழியாக உச்சந்தலையை நோக்கி எழுப்பப்படுகிறது." },
    { "key": "energy.rise.label", "locale": "en", "value": "Energy rising along the spine" },
    { "key": "energy.rise.label", "locale": "hi", "value": "रीढ़ के साथ ऊपर उठती ऊर्जा" },
    { "key": "energy.rise.label", "locale": "ta", "value": "முதுகெலும்பு வழியே எழும் ஆற்றல்" }
  ]
}
