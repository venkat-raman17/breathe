    { "key": "tech.slow_breathing.felt", "locale": "en", "value": "Calm and settled; breath and heartbeat seeming to sync." },
    { "key": "tech.breath_awareness.name", "locale": "en", "value": "Breath awareness" },
    { "key": "tech.breath_awareness.summary", "locale": "en", "value": "Rest your attention on the natural breath, returning gently whenever the mind wanders." },
    { "key": "tech.breath_awareness.felt", "locale": "en", "value": "Quiet, anchored, present." },
    { "key": "tech.box_breathing.name", "locale": "en", "value": "Box breathing" },
    { "key": "tech.box_breathing.summary", "locale": "en", "value": "Equal counts — in, hold, out, hold — to stay calm and alert." },
    { "key": "tech.box_breathing.felt", "locale": "en", "value": "Steady, contained, composed." },
    { "key": "tech.four_seven_eight.name", "locale": "en", "value": "4-7-8 breathing" },
    { "key": "tech.four_seven_eight.summary", "locale": "en", "value": "Inhale 4, hold 7, a long exhale of 8 — a relaxing pattern for winding down." },
    { "key": "tech.four_seven_eight.felt", "locale": "en", "value": "Progressively drowsy, heavy, settling." },
    { "key": "tech.four_seven_eight.safety", "locale": "en", "value": "The 7-count hold can cause light-headedness — shorten it if needed and practice seated or lying down." },
